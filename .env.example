# Get these from Supabase → Project Settings → API
# Add the same variables in Vercel → Project → Settings → Environment Variables
#
# Model (when VITE_JOURNAL_PUBLIC_USER_ID is set + matching RLS in schema.sql):
# - Anyone can READ your entries without signing in.
# - Only YOUR account (this UUID) can add or edit entries in the app; other
#   signed-in users stay read-only for the timeline.

# Must be https://<project-ref>.supabase.co (Dashboard → Settings → API → Project URL).
# If the host does not resolve (ERR_NAME_NOT_RESOLVED), check URL spelling, VPN, and that the project exists.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Your Supabase Auth user id (Authentication → Users). Same UUID as in
# journal_select_public_owner in supabase/schema.sql. Omit for a private-only app.
VITE_JOURNAL_PUBLIC_USER_ID=
